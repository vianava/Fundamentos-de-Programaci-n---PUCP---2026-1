void leer_datos(int *password) {

    printf("Ingrese su contraseña: \n");
    scanf("%d", password);

}

int es_de_seis_cifras(int password) {

    int valido=(password/100000)>=1 && (password/100000)<10;

    return valido;
}

int todas_cifras_iguales (int password) {

    int i=1, n, cifraAnterior=0, iguales=0;

    while (i<=6) {

        n=password%10;

        iguales=n==cifraAnterior;
        cifraAnterior=n;
        password=password/10;

        i++;
    }
    return iguales;
}

int tiene_ceros (int password) {
    int i=1, n, hay_ceros=0;

    while (i<=6) {
        n=password%10;

        if (n==0) {
            i=7;
            hay_ceros=1;
        }
        else {
            password/=10;
            i++;
        }
    }
    return hay_ceros;
}

void menor_digito (int password, int *min_digito, int *posicion) {

    int i=1, n;

    while (i<=6) {

        n=password/(int)pow(10,6-i);

        if (i==1) {
            *min_digito=n;
        }
        else {
            *posicion=(*min_digito<=n);
        }
        password%=(int)pow(10,6-i);
        i++;
    }
}
