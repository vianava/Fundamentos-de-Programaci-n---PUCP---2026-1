#include <stdio.h>
#include <math.h>

void leer_datos (int *tipo, int *posicion);
int calcular_numeroCasa_sumatoria (int posicion);
int calcular_numeroCasa_formula (int posicion);
int calcular_numeroLucas (int posicion);

int main(void) {

    int tipo, posicion, sumatoria, formula, lucas;

    leer_datos(&tipo, &posicion);

    if ((tipo == 1 || tipo == 2) && posicion>=0) {

        if (tipo == 1) {
            sumatoria=calcular_numeroCasa_sumatoria(posicion);
            formula=calcular_numeroCasa_formula(posicion);
            printf("El número casa en la posición %d calculado con la sumatoria es: %d\n", posicion, sumatoria);
            printf("El número casa en la posición %d calculado con la fórmula es: %d\n", posicion, formula);

            if (sumatoria==formula) {
                printf("Se comprueba que los resultados de ambas fórmulas son equivalentes.");
            }
        }
        else {
            lucas=calcular_numeroLucas(posicion);
            printf("El número Lucas en la posición %d es %d", posicion, lucas);
        }
    }
    else if (tipo!=1 || tipo!=2 && posicion>=0)
        printf("Opción inválida.");
    else
        printf("Posición inválida.");

    return 0;
}

void leer_datos (int *tipo, int *posicion) {

    printf("Seleccione (1) si desea encontrar un número casa o (2) para encontrar un número Lucas: ");
    scanf("%d", tipo);
    printf("\nIngrese la posición del número que desea encontrar: ");
    scanf("%d", posicion);

}

int calcular_numeroCasa_sumatoria (int posicion) {

    int i=1, sumatoria=0;

    while (i<=posicion) {
        sumatoria+=(int)pow(i,2);
        i++;
    }
    sumatoria+=(int)pow(posicion+1,3);

    return sumatoria;
}

int calcular_numeroCasa_formula (int posicion) {
    int formula=(8*(int)pow(posicion,3)+21*(int)pow(posicion,2)+19*posicion+6)/6;
    return formula;
}

int calcular_numeroLucas (int posicion) {
    int i=1, lucas=2, n_1=2, n_2=2;

    while (i<=posicion) {
        if (i==1) {
            lucas=1;
        }
        else {
            lucas=n_1+n_2;
        }
        n_2=n_1;
        n_1=lucas;
        i++;
    }
    return lucas;
}
